# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model routing
MODEL_PRIMARY_CHAT=tinyllama:latest
MODEL_FAST=qwen2.5:0.5b
MODEL_REASONING=qwen3.5:0.8b
MODEL_HEAVY=qwen3.5:2b

# Whisper.cpp
WHISPER_BIN=./whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=./whisper.cpp/models/ggml-tiny.en.bin

# Piper
PIPER_BIN=piper
PIPER_MODEL=./models/en_US-lessac-low.onnx
TTS_FALLBACK_BIN=/usr/bin/espeak-ng

# Uvicorn runtime (optional helper values)
APP_HOST=0.0.0.0
APP_PORT=8000
